# Environment Variables Example
#
# IMPORTANT: DO NOT put real API keys in this file!
#
# For local development:
#   1. Copy this file to .env.local
#   2. Fill in your actual values in .env.local
#   3. Never commit .env.local to git!
#
# For production:
#   Set these as environment variables in your hosting platform

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Local Development URL
VITE_SITE_URL=http://localhost:8080

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
# WARNING: Keep this secret! Never commit it to git!
VITE_OPENAI_API_KEY=sk-proj-your_openai_api_key_here
