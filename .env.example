# Environment Variables Example
#
# ВАЖНО: НЕ храни здесь реальные ключи!
#
# Для локальной разработки:
#   1. Скопируй этот файл в .env.local
#   2. Заполни реальными значениями
#   3. НЕ коммить .env.local в git!
#
# Для production:
#   Добавь эти переменные в GitHub Secrets

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SITE_URL=http://localhost:8080

# OpenAI API Key
# Получить: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-proj-your_openai_key_here
